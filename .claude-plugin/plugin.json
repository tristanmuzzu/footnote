{
  "name": "footnote",
  "description": "Always-on learning companion with spaced repetition. Claude leaves short 'Learn next' hints for unfamiliar dev terms; hooks then capture, dedupe, and re-surface them for a quick recall check at growing intervals so they actually stick.",
  "version": "2.1.0",
  "author": {
    "name": "tristanmuzzu",
    "url": "https://github.com/tristanmuzzu"
  },
  "homepage": "https://github.com/tristanmuzzu/footnote",
  "repository": "https://github.com/tristanmuzzu/footnote",
  "license": "MIT",
  "keywords": ["learning", "teaching", "education", "beginner", "mentor", "footnotes"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/footnote-activate.js",
            "timeout": 5,
            "statusMessage": "Loading footnote..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/footnote-mode-tracker.js",
            "timeout": 5,
            "statusMessage": "footnote"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/footnote-harvest.js",
            "timeout": 10,
            "statusMessage": "footnote"
          }
        ]
      }
    ]
  }
}
